# Define directories
BUILD_DIR := .build/
DEBUG_DIR := .debug/

# Changing the .o suffix to .c suffix
BUILD_OBJS := $(addprefix $(BUILD_DIR)bin/,$(OBJ_FILES))
DEBUG_OBJS := $(addprefix $(DEBUG_DIR)bin/,$(OBJ_FILES))

# Including dependency files generated by the compiler (.d from .o)
BUILD_DEPS := $(BUILD_OBJS:.o=.d)
DEBUG_DEPS := $(DEBUG_OBJS:.o=.d)

# Compiler and flags (adjust as needed)
CC := gcc
CFLAGS := -Wall -Wextra -Werror -Wno-unused-parameter -pedantic -std=c2x
LMFLAGS := -lm
DEPFLAGS := -MMD -MP
MAKEFLAGS := --no-print-directory
DEBUG_FLAGS := -g
.PHONY: all clean run all_debug
.SECONDARY: $(DEBUG_OBJS) $(BUILD_OBJS)

# Setting up the directories if the directories is not
# already there using shell command.
$(BUILD_DIR)bin/:
	@mkdir -p $(BUILD_DIR)/bin

$(DEBUG_DIR)bin/:
	@mkdir -p $(DEBUG_DIR)/bin


# Going from .c to .o file without linking any of them
$(BUILD_DIR)bin/%.o: %.c | $(BUILD_DIR)bin/
	@$(CC) $(CFLAGS) $(DEPFLAGS) -c $< -o $@
$(DEBUG_DIR)bin/%.o: %.c | $(DEBUG_DIR)bin/
	@$(CC) $(CFLAGS) $(DEBUG_FLAGS) $(DEPFLAGS) -c $< -o $@

# To include the dependencies files for all .c 
-include $(wildcard $(BUILD_DEPS) $(DEBUG_DEPS))

# Going from .o to a single program file that can run or debug
# Use by typing the main program files in the terminal and write
# make <program_name> for direct running or 
# make <program_name>_debug for a debug file to run.

$(BUILD_DIR)%: $(BUILD_DIR)bin/%.o $(BUILD_OBJS) | $(BUILD_DIR)bin/
	@$(CC) $(CFLAGS) $^ -o $@ $(LMFLAGS)

$(DEBUG_DIR)%_debug: $(DEBUG_DIR)bin/%.o $(DEBUG_OBJS) | $(DEBUG_DIR)bin/
	@$(CC) $(CFLAGS) $(DEBUG_FLAGS) $^ -o $@ $(LMFLAGS)

# Make <program> will be compile and placed in the "build" directory
# The code below turn terminal command "make <program>" into "make build/<program>"

%:
	@if [ "$(patsubst %_debug,%,$@)" = "$@" ]; then \
		$(MAKE) $(MAKEFLAGS) $(BUILD_DIR)$@; \
	else \
		$(MAKE) $(MAKEFLAGS) $(DEBUG_DIR)$@; \
	fi

# Rule to clean up the build directory
clean:
	@find $(BUILD_DIR) -type f -exec rm -f {} +
	@find $(DEBUG_DIR) -type f -exec rm -f {} +
	@echo "Cleaned up build and debug directories in current directory."
